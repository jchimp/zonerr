# Flask
FLASK_SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=0

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# BIND paths
BIND_ZONE_DIR=/etc/bind/zones
BIND_NAMED_CONF_LOCAL=/etc/bind/named.conf.local
RNDC_PATH=/usr/sbin/rndc
RNDC_KEY=
RNDC_HOST=127.0.0.1
RNDC_PORT=953

# Replication config store
REPLICATION_CONFIG=/data/replication.json
